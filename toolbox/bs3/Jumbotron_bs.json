{ 
"_type": "Jumbotron_bs", 
"_base": ["bsAll", "fonts", "borders", "margin", "padding", "colors", "bsButton", "bsBadge", "bsHeaderValue", "bsIcon", "children"], 
"_palette": 9, 
"_art": "images/jumbotron.png",
"_wikipage": "Jumbotron (Bootstrap)",
"_shorthelp": "<a href='{_docurl}'>Jumbotron</a> Use to showcase key content. Bootstrap.", 
"_category": ["All", "Bootstrap 3 (obsolete)"],

"_displayname": "Jumbotron",
"_longhelp": "longhelp",

"width": "auto",
"height": "auto",
"header": "Jumbotron",
"value": "This is the value",

"_grouping": {"type": "hidden"},
"_groupStyle": {"type": "hidden"},

"fullWidth": "", 
"_fullWidth": { 
    "acignore": true,
    "desc": "Should control be full width of screen?", 
    "type": "enum", 
    "keys": ["", "true"], 
    "values": ["", "true"]
}, 
   
"ChangeForm": "",
"_ChangeForm": {
	"acignore": true,
    "desc": "id of the form to change to when clicked.",
    "type": "str"
	},

"buttonValue": "Learn More",
"_buttonValue": {
	"acignore": true,
    "desc": "Value on button. Leave blank for no button.",
    "type": "str"
	},

"_csstemplate": [
    "#{id} {{{if _parent.position<>'static'}position:{_parent.position};{/if}{if display<>''} display:{display};{/if}{if left<>'' and left<>'auto'} left:{left!p};{/if}{if right<>'' and right<>'auto'} right:{right!p};{/if}{if top<>'' and top<>'auto'} top:{top!p};{/if}{if bottom<>'' and bottom<>'auto'} bottom:{bottom!p};{/if}{if height<>'' and height<>'auto'} height:{height!p};{/if}{if width<>'' and width<>'auto'} width:{width!p};{/if}}}",
    "\n{_childcss}"
],

"_htmltemplate": [
    "  \"{if fullWidth<>'true'}<div id='{id}' class='container'>{/if}<div {if fullWidth=='true'}id='{id}' {/if}class='jumbotron {class}' style='{_margincss!i}{_paddingcss!i}{_fontcss!i}{_colorscss!i}{_bordercss!i}{hidden}{style!j}' data-role='none'><div class=''><h1>{header!j}</h1><p>{value!j}<p>\",",
    "{if buttonValue<>''}    \"<button id='{id}_button' class='btn{appearance}{size}{blockLevel} {class}' {disabled}>{_bsIcon!i}{buttonValue!j}{_bsBadge!i}</button>\"{/if},\"<div id={id}_addChild>\",{_childhtml},\"</div>\",",
    "  \"</div></div>{if fullWidth<>'true'}</div>{/if}\","
],

"_jstemplate": [
  "  NSB.bs.addProperties({id}, '{_type}');",
  "{if ChangeForm<>''}  {id}.onclick=function(){{ChangeForm({ChangeForm})}};{/if}",
  "  {_childjs}"
  ]
		
}
