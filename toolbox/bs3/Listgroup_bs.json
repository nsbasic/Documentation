{ 
"_type": "Listgroup_bs", 
"_base": ["bsAll", "margin", "padding", "fonts", "colors", "bsItems", "bsNav", "bsPopover"], 
"_palette": 9, 
"_art": "images/listgroup.png", 
"_wikipage": "Listgroup (Bootstrap)",
"_shorthelp": "<a href='{_docurl}'>Listgroup</a> displays a choosable list. Bootstrap.",
"_category": ["All", "Bootstrap 3 (obsolete)"],

"_displayname": "Listgroup",
"_longhelp": "longhelp",

"_acprops": {
    "addItem(s)": {"desc": "Add new item s to the end."},
    "badge(n,s)": {"desc": "Set badge of line n to s."},
    "clear()": {"desc": "Remove all items."},
    "length": {"desc": "Return the number of items."},
    "value": {"desc": "The value last selected."}
},

"width": "180px",
"height": "auto",
"items": "Listgroup Item 1\n>Item 2\n*Item 3 (disabled)\nItem 4",

"itemBadges": "1\n2\n3\n4",
"_itemBadges": { 
    "acignore": true,
    "i18n": true,
    "desc": "Badges to show, one per line.", 
    "type": "css",
    "language": "HTML" 
    },
    
"appearances": "default\nsuccess\ninfo\ndanger",
"_appearances": { 
    "acignore": true,
    "desc": "Appearance of each item, one per line. Can be default, success, info, warning or danger.", 
    "type": "css" 
    }, 
                
"listStyle": "ul",
"_listStyle": { 
    "acignore": true,
    "desc": "What is the style of the Listgroup?", 
    "type": "enum",
    "keys": ["unordered list", "button list"], 
    "values": ["ul", "div"]
    }, 
                
"_htmltemplate": [
    "    NSB.bs.listgroup.make('{id}', '{_fontcss!i}{_margincss!i}{_paddingcss!i}{_colorscss!i}{hidden}{style!j}', '{class}', '{disabled}', '{items!j}', '{itemBadges!j}', '{appearances!j}', '{listStyle}', '{_bsPopover2!i}'),"
],
  
"_jstemplate": [
  "  NSB.bs.addProperties({id}, '{_type}');"
    ]
}
