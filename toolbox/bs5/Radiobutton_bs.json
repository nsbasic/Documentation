{ 
"_type": "Radiobutton_bs5", 
"_base": ["bs5All", "margin", "padding", "fonts", "Input", "colors", "bs5Input", "bs5Items", "bs5Icon", "bs5Popover", "bs5Badge"], 
"_palette": 9, 
"_art": "images/radiobutton.png", 
"_wikipage": "Radiobutton (Bootstrap)",
"_shorthelp": "<a href='{_docurl}'>Radiobutton</a> displays one or more mutually exclusive radiobuttons. Bootstrap.",
"_category": ["All", "Bootstrap 5"],

"_acprops": {
    "addItem(s)": {"desc": "Add new item s to the end."},
    "clear()": {"desc": "Remove all items."},
    "getValue(n)": {"desc": "Get the value of item n."},
    "footer": {"desc": "Change the footer."},
    "header": {"desc": "Change the header."},
    "length": {"desc": "Return the number of items."},
    "setValue(n, value)": {"desc": "Set the value of item n to True or False."}
},

"_displayname": "Radiobutton",
"_longhelp": "longhelp",
"header": "Radio",
"_placeholder": {"type": "hidden"},
"_inputmode": {"type": "hidden"},

"width": "auto",
"height": "auto",
"items": "Item #1\n>Item #2\n*Item #3 (disabled)",

"header": "", 
"_header": { 
    "i18n": true,
    "desc": "Label. Appears above the input control.", 
    "type": "str" 
   }, 

"inline": "", 
"_inline": { 
    "acignore": true,
    "desc": "Display options horizontally?", 
    "type": "enum", 
    "keys": ["", "inline"], 
    "values": ["", "-inline"]
    }, 

"appearance": " btn-secondary", 
"_appearance": { 
    "acignore": true,
    "desc": "Appearance of the button", 
    "type": "enum", 
    "keys": ["", "default", "primary", "success", "info", "warning", "danger", "link", "light", "dark"], 
    "values": ["", " btn btn-secondary", " btn btn-primary", " btn btn-success", " btn btn-info", " btn btn-warning", " btn btn-danger", " btn btn-link", " btn btn-light", " btn btn-dark"]
}, 
                
"_htmltemplate": [
    "  \"<div id={id} class='{class}{appearance}' style='{hidden}{_fontcss!i}{_margincss!i}{style}'>\",",
    "  \"{_bsInput_wrapperNoPopover!i}{_bsInput_headerColsNoBadgeNoInput!i}\",",
    "{if header<>''}    \"<div class='col-sm-{valueCols}'>\",{/if}",
    "{if header==''}    \"<div class='col-sm-12'>\",{/if}",
    "      \"{_bsBadgePadBelow!i}\",",
    "    NSB.bs.radiobutton.make('{id}', '{_fontcss!i}{_margincss!i}{_paddingcss!i}{_colorscss!i}{hidden}{style!j}', '{disabled}', '{items!j}', '{inline}', '{value}', '{required}'),",
    "{if icon<>''}        \"<div class='input-group-append'{_bsPopover!i}>\",{/if}",
    "{if icon<>''}          \"<a><span class='bi-{icon}'>&nbsp;</span></a></div>\",{/if}",
    "    \"{_bsinput_footer!i}\",",
    "  \"</div></div>\","
],
  
"_jstemplate": [
  "  NSB.bs.addProperties({id}, '{_type}');"
    ]
}
