{ 
"_type": "Alert_bs5", 
"_base": ["bs5All", "fonts", "borders", "margin", "padding", "colors", "children", "bs5HeaderValue", "bs5Badge", "bs5Icon"], 
"_palette": 9, 
"_art": "images/alert.png",
"_wikipage": "Alert (Bootstrap)",
"_shorthelp": "<a href='{_docurl}'>Alert</a> Provide feedback message to the user. Bootstrap.", 
"_category": ["All", "Bootstrap 5"],

"_displayname": "Alert",
"_longhelp": "longhelp",
"_header": {"type": "hidden"},

"width": "auto",
"height": "auto",
"text": "Alert",

"appearance": " alert-success",
"_appearance": { 
    "acignore": true,
    "desc": "Appearance of the alert", 
    "type": "enum", 
    "keys": ["success", "info", "warning", "danger"], 
    "values": [" alert-success", " alert-info", " alert-warning", " alert-danger"]
    }, 

"dismissable": "",
"_dismissable": { 
    "acignore": true,
    "desc": "Add an x to dismiss the alert?", 
    "type": "enum", 
    "keys": ["", "true"], 
    "values": ["", "true"]
    }, 

"_htmltemplate": [
    "  \"<div id='{id}' class='alert{appearance} {class}{if dismissable=='true'} alert-dismissible{/if}' style='{_margincss!i}{_paddingcss!i}{_fontcss!i}{_colorscss!i}{_bordercss!i}{hidden}{style!j}' data-i18n='{value!j}'>{_bsIcon!i}{if dismissable=='true'}<button type='button' class='btn-close' <span></span></button>{/if}{value!j}{_bsBadge!i}\",{_childhtml},\"</div>\","
],

"_jstemplate": [
  "  NSB.bs.addProperties({id}, '{_type}');",
  "{if dismissable=='true'}  {id}.onclick = function() {{{id}.hide();}};{/if}"
    ]
		
}
