{ 
"_type": "Dropdown_bs5", 
"_base": ["bs5All", "fonts", "borders", "margin", "padding", "colors", "bs5Button", "bs5Badge", "bs5Items", "bs5Popover"], 
"_palette": 9, 
"_art": "images/dropdown.png",
"_wikipage": "Dropdown (Bootstrap)",
"_shorthelp": "<a href='{_docurl}'>Dropdown</a> drops a list of choices down (or up). Grouping only works on horizontal. Bootstrap.", 
"_category": ["All", "Bootstrap 5"],
"_displayname": "Dropdown",
"_longhelp": "longhelp",

"_acprops": {
    "addItem(s)": {"desc": "Add new item s to the end."},
    "clear()": {"desc": "Remove all items."},
    "enable(index,enable)": {"desc": "Toggle Enable/Disable for item in control. Use 'All' to set all items."},
    "length": {"desc": "Return the number of items."},
    "selection": {"desc": "The text of the item selected."},
    "value": {"desc": "The value last selected."}
},

"value": "Dropdown",
"width": "auto",
"height": "auto",
"icon": "caret",
"items": "!Heading\nItem 1\nItem 2\n-\n*Item 3 (disabled)",

"dropdown": "dropdown", 
"_dropdown": { 
    "acignore": true,
    "desc": "Dropdown, Dropup, Dropright or Dropleft?", 
    "type": "enum", 
    "keys": ["dropdown", "dropup", "dropright", "dropleft"], 
    "values": ["dropdown", "dropup", "dropright", "dropleft"] 
    }, 

"align": "", 
"_align": { 
    "acignore": true,
    "desc": "How should text in dropdown be aligned?", 
    "type": "enum", 
    "keys": ["left", "right"], 
    "values": ["", " dropdown-menu-right"] 
    }, 

"filter": "false", 
"_filter": { 
    "acignore": true,
    "desc": "Should options be filtered?", 
    "type": "enum", 
    "keys": ["false", "true"], 
    "values": ["false", "true"] 
    }, 

"filterPlaceholder": "Search...", 
"_filterPlaceholder": { 
    "acignore": true,
    "desc": "Text to show in search box.", 
    "type": "str"
    }, 

"_htmltemplate": "  NSB.bs.dropdown.make('{id}', '{value}', '{dropdown}', '{blockLevel} {class}', '{disabled}', '{_fontcss!i}{_bordercss!i}{_margincss!i}{_paddingcss!i}{_colorscss!i}{hidden}{style!j}', '{_fontcss!i}{_bordercss!i}{_margincss!i}{_paddingcss!i}{_colorscss!i}{hidden}{style!j}', '{appearance}', '{outline}', '{size}', '{icon}', '', '{align}', '{items!j}', '{grouping}', '{groupStyle}', '{_bsBadge!i}', '{_bsPopover2!i}', '{filter}', '{filterPlaceholder}'),",

"_jstemplate": [
  "  NSB.bs.addProperties({id}, '{_type}');"
    ],
    
"_design_jstemplate": [
    "{id}.getDesignFrameRect = function() {{",
    "  return {id}_button.getBoundingClientRect();",
    "}}"
    ]
}
