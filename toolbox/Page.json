    "pathTo_jqWidgets": "https://jqwidgets.com/public/jqwidgets/", 
    "_pathTo_jqWidgets": { 
        "display": "jqWidgetsPath",
        "desc": "The path to the jqWidgets files. If to a local folder, should end in /. Must be single line.", 
        "group": "Frameworks",
        "language": "Text",
        "type": "css" 
        }, 
        
    "jqWidgetsLicence": "", 
    "_jqWidgetsLicence": { 
        "desc": "Your jqWidgets license. Get it from jqwidgets.com", 
        "group": "Frameworks",
        "language": "Text",
        "type": "css" 
        }, 

    "pathTo_bootstrap": "", 
    "_pathTo_bootstrap": { 
        "display": "BootstrapPath",
        "group": "Frameworks",
        "desc": "The path to the Bootstrap. If to a local folder, should end in /. Must be single line.", 
        "language": "Text",
        "type": "css" 
        }, 

    "script": "",
    "_script": {
        "acignore": true,
        "desc": "The code associated with this object.",
        "type": "css",
        "external": ["modules", "{if language=='BASIC'}globalcode.bas{/if}{if language=='JavaScript'}globalcode.js{/if}"]
    },
    "_cached_js": {
        "acignore": true,
        "type": null,
        "external": ["cache", "globalcode.cache"]
    },
    "_cached_js_script_hash": {
        "acignore": true,
        "type": null,
        "external": ["cache", "globalcode.hash"]
    },
    "_expanded_pmp": {
        "acignore": true,
        "type": "json",
        "external": ["cache", "globalcode.pmp"]
    },
    
    "_htmltemplate": [
        "<!DOCTYPE HTML>",
        "<html lang={lang}{if rtl<>''} dir=rtl{/if}>",
        "<head>",
        "<meta charset=\"utf-8\">",
        "<title>{title}</title>",
        "<meta name=\"generator\" content=\"{nsbx_build}\" />",
        "<meta name='date' content='{nsbx_timestamp}' />",
        "<meta name='Description' content='{if description<>''}{description}{/if}{if description==''}{title}{/if}' />",
        "<meta name='version' content='{version}' />",
        "<meta name='BuildCounter' content='{nsbx_buildcounter}' />",
        "<meta name='viewport' content='width=device-width, initial-scale=1, user-scalable=no viewport-fit={viewportFit}' />",
        "<meta name='theme-color' content='#000000' />",
        "<meta name='mobile-web-app-capable' content='yes' />",
        "<meta name='apple-mobile-web-app-status-bar-style' content='{statusbar}' />",
        "<meta name='apple-mobile-web-app-title' content='{homescreenTitle}' />",
        "<meta name='copyright' content='{copyright}' />",
        "{if contentSecurityPolicy<>''}<meta http-equiv='Content-Security-Policy' content=\"{contentSecurityPolicy}\" />{/if}",
        "{if icon<>''}<link rel='apple-touch-icon' href='{_nsbdir}{icon}' />{/if}",
        "{if icon<>''}<link rel='shortcut icon' href='{_nsbdir}{icon}' />{/if}",
        "{if extraheaders.find('Electron')>=0}<script>window.$ = window.jQuery = require('./nsb/library/jquery3.js');</script>{/if}",
        "{if disablePWA==''}<link href='manifest.json' rel='manifest' />{/if}",
        "{_reqheaders}",
        "{if hiddenheaders<>''}{hiddenheaders}{/if}",        
        "{if extraheaders<>''}{extraheaders}{/if}",        
        "{_css}",
        "{if styleheaders<>''}<style>{/if}",
        "{if styleheaders<>''}{styleheaders}{/if}",
        "{if styleheaders<>''}</style>{/if}",
        "{_headjs}",
        "</head>",
        "<body style=\"margin:0px;-ms-touch-action:none;background:inherit;{if fontFamily<>'system' and fontFamily<>''}font-family:{fontFamily};{/if}{if fontFamily=='system'}-apple-system, '.SFNSText-Regular', 'San Francisco', 'Roboto', 'Segoe UI', 'Helvetica Neue';{/if}{if background<>''} background-color:{background}; {/if}{if background==''} background-color:inherit; {/if}{style!j}\">",
        "<noscript><h1>JavaScript must be enabled!</h1></noscript>",
        "<div data-role=\"page\" id=\"NSBPage\" data-theme=\"{theme}\" style=\"position:absolute; width:100%; height:100%; background-color:inherit; {if backgroundimage<>'' and backgroundimage[:16]=='linear-gradient('}background-image:{backgroundimage};{/if}{if backgroundimage<>'' and backgroundimage[:16]<>'linear-gradient('}background-image:url('{backgroundimage}');{/if}\">",
        "{_childhtml}",
        "</div>",
        "{_js}",
        "<script src=\"code.js\"></script>",
        "{_dbheaders}",
        "</body>",
        "</html>"
    ],

    "_csstemplate": [
        "<style type=\"text/css\">\n",
        "\n{_childcss}",
        "\n</style>"
    ],

    "_headjstemplate": "{_childheadjs}",

    "_jstemplate": ["<script>",
        "if(!navigator.cookieEnabled) NSB.MsgBox('Please turn cookies on.');",
        "(function(){{var all=document.getElementsByTagName('*');for(var i=0;i<all.length;i++)if(all[i].id!=''&&typeof all[i].id!='undefined'&&typeof window[all[i].id]=='undefined')window[all[i].id]=all[i];}})()",
        "var NSB = NSB || {{}};",
        "NSB.currentForm = {firstform};",
        "NSB.stopOnError = {stopOnError};",
        "NSB.enableBrowserArrows = {enableBrowserArrows};",
        "NSB.enableAppScroll = {enableAppScroll};",
        "NSB.id = '{id}';",
        "NSB.initLanguage();",
        "NSB.voltAppId = '{voltAppId}';",
        "NSB.voltDashboardAccess = {dashboardAccess};",
        "NSB.voltDomain = '{voltDomain}';",
        "{if disablePWA==''}NSB.PWA = true;{/if}",
        "{if disablePWA=='false'}NSB.PWA = false;{/if}",
        "{if enableBrowserArrows == 'true'}var router = new Navigo(null, !{enableNiceLinks});{/if}",
        "{if enableBrowserArrows == 'true'}router.on(function() {{ChangeFormAction({firstform});}});{/if}",
        "if ($.mobile != undefined) $.mobile.hashListeningEnabled = false;",
        "NSB.EULAtext='{EULA!j}';",
        "",
        "{_childjs}",
        "",
        "window.addEventListener('orientationchange', function(){{window.scrollTo(0,0)}});",
        "window.addEventListener('load', function() {{",
        "  if (typeof($().i18n) === 'function') $('[data-i18n]').i18n();",
        "{if voltAppId <> ''}  if (window.$volt) $volt.init('{if dashboardAccess <> 'true'}{voltAppId}{/if}{if dashboardAccess == 'true'}RpYCMN{/if}', NSB.voltDomain);{/if}",
        "{if browserwarnmsg<>''}  browserWarningMessage('{browserwarnmsg}');{/if}",
        "{if enableBrowserArrows == 'false'}  {firstform}.style.display = 'block';{/if}",
        "{if enableBrowserArrows == 'true'}  router.resolve();{/if}",  
        "{if jqWidgetsLicence<>''}  if ($.jqx) $.jqx.credits = '{jqWidgetsLicence}';{/if}",
        "  if (typeof(cordova)==='undefined') NSB.preMain();",
        "}}, false);",
        "document.addEventListener('deviceready', function() {{",
        "  console.log('Cordova deviceready')",
        "  if (typeof(cordova)!=='undefined') NSB.preMain();",
        "}}, false);",
        "</script>"
    ],
    "_design_jstemplate": "<script>{_childdesignjs}</script>"
}
