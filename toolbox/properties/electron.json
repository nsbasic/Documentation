{
    "_type": "electron",
    "_base": "NSBObject",
    "_description": "electron specific properties, Used in Page.js",

    "electronPackage": [
      "{",
      "  \"name\": \"{title}\",",
      "  \"version\": \"{version}\",",
      "  \"description\": \"{description}\",",
      "  \"main\": \"electronMain.js\",",
      "  \"scripts\": {",
      "    \"start\": \"electron .\",",
      "    \"pack\": \"electron-builder --dir\",",
      "    \"dist\": \"electron-builder\"",
      "  },",
      "  \"author\": \"\",",
      "  \"license\": \"ISC\",",
      "  \"repository\": \"\",",
      "  \"devDependencies\": {",
      "    \"electron\": \"^40.8.0\",",
      "    \"electron-builder\": \"^26.8.1\",",
      "    \"npm\": \"^11.11.0\"",
      "  },",
      "  \"dependencies\": \"{dependencies}\",",
      "  \"build\": {",
      "    \"appId\": \"{id}\",",
      "    \"mac\": {",
      "      \"category\": \"public.app-category.developer-tools\"",
      "    }",
      "  }",
      "}"
      ],
      
    "_electronPackage": {
        "display": "package.json",
        "group": "Electron",
        "acignore": true,
        "desc": "Parameters for Electron apps. <a href='https://docs.npmjs.com/files/package.json'>More Info</a>",
        "type": "css",
        "external": ["properties", "package.json"]
    },

    "electronPackageLock": [
      "{",
      "}"
      ],
      
    "_electronPackageLock": {
        "display": "package-lock.json",
        "group": "Electron",
        "acignore": true,
        "desc": "NPM package lockfile for Electron apps. Placeholder - no need to edit. <a href='https://docs.npmjs.com/files/package.json'>More Info</a>",
        "type": "css",
        "external": ["properties", "package-lock.json"]
    },

    "electronMain": [
      "/* globals",
      "  require:false",
      "  process:false",
      "  electronDevTools:false",
      "*/",
      "",
      "// eslint-disable-next-line",
      "const { app, BrowserWindow, Menu } = require('electron');",
      "",
      "// eslint-disable-next-line",
      "const openDevTools = {electronDevTools};",
      "",
      "let mainWindow;",
      "",
      "// eslint-disable-next-line",
      "function createWindow() {",
      "  'use strict';",
      "",
      "  // see https://electronjs.org/docs/api/browser-window for all options",
      "  mainWindow = new BrowserWindow({",
      "    width: (openDevTools) ? 768 + 512 : 768,",
      "    height: 1004,",
      "    title: '{title}',",
      "    webPreferences: { nodeIntegration: true, contextIsolation: false, enableRemoteModule: true, },",
      "  });",
      "",
      "  // set headers to enable SharedArrayBuffer for SQLite WASM",
      "  mainWindow.webContents.session.webRequest.onHeadersReceived((details, callback) => {",
      "    details.responseHeaders = details.responseHeaders || {};",
      "    details.responseHeaders['Cross-Origin-Opener-Policy'] = ['same-origin'];",
      "    details.responseHeaders['Cross-Origin-Embedder-Policy'] = ['require-corp'];",
      "    callback({ responseHeaders: details.responseHeaders });",
      "  });",
      "",
      "  mainWindow.loadFile('index.html');",
      "",
      "  if (openDevTools) mainWindow.webContents.openDevTools();",
      "",
      "  mainWindow.on('closed', () => {",
      "    mainWindow = null;",
      "  });",
      "}",
      "",
      "app.whenReady().then(createWindow);",
      "",
      "app.on('window-all-closed', () => {",
      "  'use strict';",
      "",
      "  if (process.platform !== 'darwin') app.quit();",
      "});",
      "",
      "app.on('activate', () => {",
      "  'use strict';",
      "",
      "  if (BrowserWindow.getAllWindows().length === 0) {",
      "    createWindow();",
      "  }",
      "});",
      ""
    ],
      
    "_electronMain": {
        "display": "electronMain.js",
        "group": "Electron",
        "acignore": true,
        "desc": "Startup module for Electron app. <a href='https://electronjs.org/docs/api/browser-window'>More Info</a>",
        "type": "css",
        "external": ["properties", "electronMain.js"]
    },

    "electronDevTools": "true",
    "_electronDevTools": {
        "display": "Chrome Dev Tools?",
        "group": "Electron",
        "desc": "Open Chrome Dev Tools automatically?",
        "type": "enum",
        "keys": ["False", "True"],
        "values": ["false", "true"]
    },
    
    "electronIcon": "",
    "_electronIcon": {
        "group": "Electron",
        "display": "icon (512)",
        "desc": "Icon template. Must be 512x512 png, jpg or jpeg. If not supplied, AppStudio icon will be used.",
        "type": "image"
    }
}
