{
    "_type": "pwa",
    "_base": "NSBObject",
    "_description": "PWA specific properties, Used in Page.js",

    "disablePWA": "",
    "_disablePWA": {
        "group": "Progressive Web App",
        "display": "Make PWA?",
        "desc": "Make a Progressive Web App? Default is true.",
        "type": "enum",
        "keys": ["true", "false"],
        "values": ["", "false"]
    },

		"PWA_Manifest": [
			"{",
			"  \"short_name\": \"{title}\",",
			"  \"name\": \"{title}\",",
			"  \"description\": \"{description}\",",
			"  \"display\": \"standalone\",",
			"  \"start_url\": \"index.html\",",
			"  \"background_color\": \"black\",",
			"  \"theme_color\": \"black\",",
			"  \"icons\": [",
			"    {",
			"      \"src\": \"nsb/images/72.png\",",
			"      \"sizes\": \"72x72\"",
			"    },",
			"    {",
			"      \"src\": \"{icon}\",",
			"      \"sizes\": \"192x192\"",
			"    },",
			"    {",
			"      \"src\": \"nsb/images/512.png\",",
			"      \"sizes\": \"512x512\"",
			"    }",
			"  ]",
			"}"
			],
			
		"_PWA_Manifest": {
				"display": "manifest",
        "group": "Progressive Web App",
				"acignore": true,
				"desc": "Manifest template for PWA apps. See <a href='https://wiki.appstudio.dev/Progressive_Web_Apps'>PWA docs.</a>",
				"type": "css",
				"external": ["properties", "manifest.json"]
		}
}