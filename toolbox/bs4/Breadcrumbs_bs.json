{ 
"_type": "Breadcrumbs_bs4", 
"_base": ["bs4All", "fonts", "borders", "margin", "padding", "colors", "bs4Nav", "bs4Popover"], 
"_palette": 9, 
"_art": "images/breadcrumbs.png",
"_wikipage": "Breadcrumbs (Bootstrap)",
"_shorthelp": "<a href='{_docurl}'>Breadcrumbs</a> shows the navigation to the current page. Bootstrap.", 
"_category": ["All", "Bootstrap 4"],

"_displayname": "Breadcrumbs",
"_longhelp": "longhelp",

"_acprops": {
    "length": {"desc": "Return the number of items."},
    "setValue(array)": {"desc": "Sets the list of items."}
},

"width": "auto",
"height": "auto",
"borderStyle": "",

"items": "['Breadcrumb','Customer','Order']",
"_items": { 
    "acignore": true,
    "desc": "Initial value of breadcrumb array. Updated at runtime.", 
    "type": "css"
    }, 

"_htmltemplate": [
    "  \"<ol id='{id}' class='breadcrumb {class}' style='{_margincss!i}{_paddingcss!i}{_fontcss!i}{_colorscss!i}{_bordercss!i}{hidden}{style!j}'{disabled} onclick=''{_bsPopover!i}></ol>\","
],

"_jstemplate": [
  "  NSB.bs.addProperties({id}, '{_type}');",
  "  {id}.setValue({items})"
]
		
}
