{ 
"_type": "ColorPicker_jqw", 
"_base": ["jqxAll"],
"_palette": 4, 
"_art": "images/jqxcolorpicker.png", 
"_wikipage": "jqxColorPicker",
"_shorthelp": "<a href='{_docurl}'>ColorPicker</a> Use to easily pick a color. jqWidgets (Commercial)",
"_category": ["jqWidgets"],
"_resizable": true,
"_requiredfiles": [ 
    "{pathTo_jqWidgets}jqxcore.js", 
    "{pathTo_jqWidgets}styles/jqx.base.css", 
    "{pathTo_jqWidgets}styles/jqx.{theme}.css",    
	"{pathTo_jqWidgets}jqxcolorpicker.js",
    "{pathTo_jqWidgets}jqxradiobutton.js",
    "{pathTo_jqWidgets}styles/images/colorpicker/map-saturation-overlay.png",
    "{pathTo_jqWidgets}styles/images/colorpicker/bar-saturation.png",
    "{pathTo_jqWidgets}styles/images/colorpicker/map-saturation.png",
    "{pathTo_jqWidgets}styles/images/pointer.png",
    "{pathTo_jqWidgets}styles/images/crosshair-white.png"
    ],
  
"width": 200, 
"height": 200, 

"_displayname": "ColorPicker",
"_longhelp": "longhelp",

"class": "needsclick",

"name": "", 
"_name": { 
    "desc": "Key in submitted form", 
    "type": "str" 
    }, 
    
"colorMode": "saturation", 
"_colorMode": { 
    "desc": "sets the colorMode property", 
    "type": "enum",
    "keys": ["Hue", "Saturation"], 
    "values": ["hue","saturation"]
    },
    
"showTransparent": "false", 
"_showTransparent": { 
    "desc": "sets the showTransparent property", 
    "type": "enum", 
    "keys": ["False", "True"], 
    "values": ["false","true"]
    },

"_csstemplate": [
   "#{id}_wrapper {{{if _parent.position<>'static'}position:{_parent.position};{/if}{if display<>''} display:{display};{/if}{_cssbounds!i}}}",
   "\n#{id} {{position:relative; left:0px; top:0px; height:100%; width:100%}}"],
       
"_htmltemplate": "  \"<div id='{id}_wrapper' style='background-color:white;{hidden}{style!j}' class='{class}'><div id='{id}'></div></div>\",",
"_jstemplate": [
  "  NSB.jqxSettings['{id}']={{",
  "    disabled:{disabled},",
  "    width:'{width}',",
  "    height:'{height}',",
  "    colorMode:'{colorMode}',",
  "    showTransparent:{showTransparent}",
  "  }}",
  "  {id}.style.position='relative';",
  "  $('#{id}').jqxColorPicker (NSB.jqxSettings['{id}'])",
  "  NSB.addProperties({id},{id}_wrapper);"]
}
