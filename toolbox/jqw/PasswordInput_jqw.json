{ 
"_type": "PasswordInput_jqw", 
"_base": ["jqxAll"],
"_palette": 4, 
"_art": "images/jqxpasswordinput.png", 
"_wikipage": "jqxPasswordInput",
"_shorthelp": "<a href='{_docurl}'>PasswordInput</a> Input field for a password. jqWidgets (Commercial)",
"_category": ["jqWidgets"],
"_resizable": true,
"_requiredfiles": [
    "{pathTo_jqWidgets}jqxcore.js", 
    "{pathTo_jqWidgets}styles/jqx.base.css", 
    "{pathTo_jqWidgets}styles/jqx.{theme}.css",    
    "{pathTo_jqWidgets}styles/images/icon-showpassword.png",    
    "{pathTo_jqWidgets}jqxpasswordinput.js",
    "{pathTo_jqWidgets}jqxtooltip.js"
    ],
  
"_displayname": "PasswordInput",
"_longhelp": "longhelp",

"_acprops": {
	},

"height": 25, 
"width": 150, 

"name": "", 
"_name": { 
    "desc": "Key in submitted form", 
    "type": "str" 
    }, 
    

"maxLength": 16, 
"_maxLength": { 
    "desc": "Set maximum number of characters for password", 
    "type": "int"
    },
    
"placeHolder": "", 
"_placeholder": { 
    "desc": "Placeholder text", 
    "type": "str" 
    },

"showPasswordIcon": "true", 
"_showPasswordIcon": { 
    "desc": "Gets or sets whether the Show/Hide password icon will appear.", 
    "type": "enum", 
    "keys": ["False", "True"], 
    "values": ["false","true"]
    },

"showStrength": "true", 
"_showStrength": { 
    "desc": "Gets or sets whether a tooltip which shows the password's strength will be shown.", 
    "type": "enum", 
    "keys": ["False", "True"], 
    "values": ["false","true"]
    },

"onchange": "", 
"_onchange": { 
    "acignore": true,
    "desc": "This event is triggered when the value is changed and the control's focus is lost.", 
    "type": "js" 
    }, 

    
"_htmltemplate": "  \"<input type='password' id='{id}' data-role='none' style='{hidden}{style!j}' class='{class}'>\",",

"_jstemplate": [
    "  NSB.jqxSettings['{id}']={{",
        "    disabled:{disabled},",
        "    width:'{width}',",
        "    height:'{height}',",
        "    rtl:{rtl},",
        "    theme:'{theme}',",
		"    showPasswordIcon: {showPasswordIcon},",
		"    showStrength: {showStrength},",
		"    maxLength: {maxLength},",
        "    placeHolder: '{placeHolder}',",
	 "  }}",
    "  $('#{id}').jqxPasswordInput(NSB.jqxSettings['{id}']);",
    "  NSB.addProperties({id});"]
}
